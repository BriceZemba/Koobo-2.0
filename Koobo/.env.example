# Copiez ce fichier en « .env » et renseignez vos propres clés.
# NE JAMAIS committer le fichier .env réel.

# LLM + vision : OpenRouter (https://openrouter.ai/keys) OBLIGATOIRE
OPENROUTER_API_KEY=your_openrouter_api_key

# Reconnaissance vocale (Groq Whisper) pour l'entrée micro
GROQ_API_KEY=your_groq_api_key

# Météo / autocomplétion de villes (OpenWeather)
WEATHER_API_KEY=your_openweather_api_key

# Clé secrète Flask (sessions)
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# --- Optionnel ---
# Modèles OpenRouter (valeurs par défaut si non renseignés) :
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_VISION_MODEL=google/gemma-4-31b-it:free
# Modèle d'embeddings local (fastembed) :
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Traçage LangSmith :
LANGCHAIN_API_KEY=
# Origines CORS autorisées en prod (séparées par des virgules) :
CORS_ORIGINS=*
