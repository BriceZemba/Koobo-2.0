# URL publique de l'API Flask (laisser vide quand Flask sert le frontend : même origine).
# En dev séparé / déploiement séparé, ex. : https://koobo.onrender.com
VITE_API_URL=

# Numéro WhatsApp (format international sans "+"), ex. 22676887618.
# Laisser vide tant que vous n'avez pas de numéro / sandbox Twilio.
VITE_WHATSAPP_NUMBER=

# Supabase historique des conversations du chat.
# Laisser vide = l'historique est sauvegardé localement (localStorage).
# Renseigner = l'historique est sauvegardé dans le cloud Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
